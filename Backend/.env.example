# VARIABLES DE ENTORNO — semana-14
#
# INSTRUCCIONES:
#   1. Copia este archivo y nómbralo  .env
#   2. Rellena los valores con tus credenciales de PostgreSQL
#   3. Nunca subas el archivo .env a GitHub (agrega .env al .gitignore)
#
# En PowerShell puedes setear las variables sin archivo .env así:
#   $env:DB_PASSWORD = "tu_password"
#   uvicorn main:app --reload
# ─────────────────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
